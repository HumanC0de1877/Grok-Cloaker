generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  fullName  String
  username  String     @unique
  email     String     @unique
  phone     String?
  password  String
  plan      String     @default("starter") // starter | pro | black
  apiKey    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  campaigns Campaign[]
  domains   Domain[]
}

model Campaign {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  slug           String       @unique
  prismaId       String       @unique
  status         String       @default("active") // active | paused
  safeUrl        String
  moneyUrl       String
  trafficSource  String       @default("facebook") // facebook | tiktok | google | kwai
  riskScore      Int          @default(75)
  countries      String       @default("[]")
  languages      String       @default("[]")
  advancedConfig String       @default("{}") @db.Text
  visitors       Int          @default(0)
  blockedCount   Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  logs           TrafficLog[]

  @@index([userId])
  @@index([slug])
}

model TrafficLog {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ip         String
  country    String?
  device     String?
  platform   String?
  status     String   // allowed | blocked
  reason     String?
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([status, createdAt])
  @@index([score, createdAt])
}

model Domain {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String   @unique
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BehavioralLog {
  id             String   @id @default(cuid())
  campaignId     String
  fingerprint    String
  isBot          Boolean  @default(false)
  cpuCores       Int?
  deviceMemory   Int?
  platform       String?
  languages      String?
  screenRes      String?
  hasWebdriver   Boolean  @default(false)
  mouseMovements Int      @default(0)
  clicks         Int      @default(0)
  scrollDepth    Int      @default(0)
  timeOnPage     Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([campaignId, createdAt])
}
